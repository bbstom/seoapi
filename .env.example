# Claude API 配置
CLAUDE_API_KEY=your_api_key_here
CLAUDE_BASE_URL=https://api.api123.icu

# 服务配置
PORT=8000

# 环境配置
# development - 开发环境（本地测试）
# production - 生产环境（部署到服务器）
NODE_ENV=development

# 开发环境：跳过登录速率限制（设置为 true 完全禁用限制，生产环境请删除或设为 false）
SKIP_RATE_LIMIT=true

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=seoapi
